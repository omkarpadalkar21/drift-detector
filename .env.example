# ===========================================================================
# Drift Detector — Root .env for Docker Compose
# Copy this file to .env and fill in your values.
# ===========================================================================

# ---------------------------------------------------------------------------
# Dashboard — Database (Neon PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# ---------------------------------------------------------------------------
# Dashboard — Better Auth
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET="some-random-long-secret-key"
# BETTER_AUTH_URL is set automatically by docker-compose to http://localhost:3000

# ---------------------------------------------------------------------------
# Dashboard — GitHub OAuth App credentials
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ---------------------------------------------------------------------------
# Dashboard → AI Service connection
# Set automatically by docker-compose; override only for custom deployments.
# ---------------------------------------------------------------------------
# FASTAPI_BASE_URL=http://ai-service:8001
